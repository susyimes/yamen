{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/susyimes/yamen/contracts/prefect-report.schema.json",
  "title": "Yamen Prefect Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "case_title",
    "mode",
    "final_status",
    "route_taken",
    "summary",
    "reply_to_prefect",
    "reported_by",
    "reported_at"
  ],
  "properties": {
    "case_id": { "type": "string", "minLength": 1 },
    "case_title": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "enum": ["direct", "filed", "reviewed"] },
    "final_status": {
      "type": "string",
      "enum": ["done", "returned", "cancelled", "failed"]
    },
    "route_taken": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["entry", "zhubu", "kuaishou", "dianshi"]
      }
    },
    "summary": { "type": "string", "minLength": 1 },
    "reply_to_prefect": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "summary"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "path": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      },
      "default": []
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "review_notes": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "runtime_outcome": {
      "type": "string",
      "enum": ["normal", "degraded", "failed"],
      "default": "normal"
    },
    "reported_by": { "const": "entry" },
    "reported_at": { "type": "string", "format": "date-time" }
  }
}
