{
  "version": 1,
  "defaultProvider": "stub",
  "providers": {
    "stub": {
      "kind": "stub"
    },
    "file": {
      "kind": "file",
      "requestDir": "runtime/bridge/requests",
      "responseDir": "runtime/bridge/responses",
      "timeoutMs": 1000,
      "pollIntervalMs": 100
    },
    "exec": {
      "kind": "exec",
      "command": "node runtime/openclaw-session-bridge.example.js",
      "timeoutMs": 30000
    },
    "openclaw-session": {
      "kind": "openclaw-session",
      "requestDir": "runtime/bridge/openclaw-session/requests",
      "responseDir": "runtime/bridge/openclaw-session/responses",
      "runtime": "subagent",
      "agentId": "main",
      "sessionMode": "spawn",
      "sessionLabelPrefix": "yamen-role",
      "timeoutMs": 60000,
      "pollIntervalMs": 1000
    }
  },
  "roles": {
    "menfang": {
      "provider": "stub"
    },
    "xianling": {
      "provider": "stub"
    },
    "zhubu": {
      "provider": "openclaw-session"
    },
    "kuaishou": {
      "provider": "openclaw-session"
    },
    "dianshi": {
      "provider": "stub"
    },
    "zhangfang": {
      "provider": "stub"
    }
  }
}
