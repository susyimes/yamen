      "sessionMode": "spawn",
      "spawnMode": "reuse-or-spawn",
      "purpose": "merged_menfang_xianling_entry"
    },
    "menfang": {
      "managedBy": "entry-session",
      "enabled": true,
      "delegatedTo": "entry"
    },
    "xianling": {
      "managedBy": "entry-session",
      "enabled": true,
      "delegatedTo": "entry"
    },
    "zhubu": {
      "managedBy": "openclaw-session",
      "enabled": true,
      "sessionLabel": "yamen-zhubu",
      "runtime": "subagent",
      "agentId": "main",
      "sessionMode": "spawn",
      "spawnMode": "reuse-or-spawn",
      "purpose": "draft_case_note_and_deliverables"
    },
    "kuaishou": {
      "managedBy": "openclaw-session",
      "enabled": true,
      "sessionLabel": "yamen-kuaishou",
      "runtime": "subagent",
      "agentId": "main",
      "sessionMode": "spawn",
      "spawnMode": "reuse-or-spawn",
      "purpose": "execute_task_and_submit_result"
    },
    "dianshi": {
      "managedBy": "openclaw-session",
      "enabled": true,
      "sessionLabel": "yamen-dianshi",
      "runtime": "subagent",
      "agentId": "main",
      "sessionMode": "spawn",
      "spawnMode": "reuse-or-spawn",
