{
  "version": 1,
  "root": ".openclaw/yamen-runtime",
  "auth": {
    "strategy": "copy-main-profile",
    "source": "..\\agents\\main\\agent\\auth-profiles.json",
    "targetName": "auth-profiles.json"
  },
  "prefect": {
    "sessionLabel": "yamen-prefect",
    "role": "prefect",
    "managedBy": "openclaw-session",
    "runtime": "subagent",
    "agentId": "main",
    "sessionMode": "session",
    "spawnMode": "reuse-or-spawn"
  },
  "entry": {
    "sessionLabel": "yamen-entry",
    "role": "menfang+xianling",
    "managedBy": "openclaw-session",
    "runtime": "subagent",
    "agentId": "main",
    "sessionMode": "spawn",
    "spawnMode": "reuse-or-spawn"
  },
  "roles": {
    "prefect": {
      "workspace": "workspace-prefect",
      "files": ["AGENTS.md", "SOUL.md", "role.json", "auth-profiles.json"]
    },
    "entry": {
      "workspace": "workspace-entry",
      "files": ["AGENTS.md", "SOUL.md", "role.json", "auth-profiles.json"]
    },
    "zhubu": {
      "workspace": "workspace-zhubu",
      "files": ["AGENTS.md", "SOUL.md", "role.json", "auth-profiles.json"]
    },
    "kuaishou": {
      "workspace": "workspace-kuaishou",
      "files": ["AGENTS.md", "SOUL.md", "role.json", "auth-profiles.json"]
    },
    "dianshi": {
      "workspace": "workspace-dianshi",
      "files": ["AGENTS.md", "SOUL.md", "role.json", "auth-profiles.json"]
    }
  }
}
