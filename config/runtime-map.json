{
  "version": 1,
  "openclaw": {
    "phase1": {
      "mainSession": {
        "actsAs": ["external-caller"],
        "responsibilities": [
          "open_or_reach_yamen_prefect",
          "observe_visible_yamen_agent_threads"
        ]
      },
      "yamenPrefect": {
        "actsAs": ["prefect"],
        "label": "yamen-prefect",
        "visibility": "openclaw-standard-visible",
        "responsibilities": [
          "receive_user_visible_tasks",
          "submit_task_to_yamen_entry",
          "review_status",
          "receive_entry_report",
          "reply_back_to_user"
        ]
      },
      "yamenEntry": {
        "actsAs": ["menfang", "xianling"],
        "label": "yamen-entry",
        "responsibilities": [
          "read_rules",
          "triage_request",
          "select_mode",
          "spawn_support_roles",
          "merge_results",
          "reply_prefect"
        ]
      },
      "spawnOnDemand": {
        "zhubu": {
          "when": ["filed", "reviewed"],
          "purpose": "draft_case_note_and_deliverables"
        },
        "kuaishou": {
          "when": ["direct", "filed", "reviewed"],
          "purpose": "execute_task"
        },
        "dianshi": {
          "when": ["reviewed"],
          "purpose": "risk_review"
        }
      }
    }
  }
}
